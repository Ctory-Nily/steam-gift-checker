{
  "manifest_version": 3,
  "name": "Steam Gift Region Checker",
  "version": "1.0.0",
  "description": "Check if you can gift Steam games between different countries",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "https://api.steaminventoryhelper.com/*",
    "https://steamdb.info/*",
    "https://store.steampowered.com/*",
    "https://api.allorigins.win/*"
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["utils/*", "lib/*"],
      "matches": ["https://store.steampowered.com/*"]
    }
  ]
}